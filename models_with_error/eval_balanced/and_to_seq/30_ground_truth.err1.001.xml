<testset xmlns="http://cpee.org/ns/properties/2.0">
  <executionhandler>ruby</executionhandler>
  <dataelements/>
  <endpoints>
    <user>https-post://cpee.org/services/timeout-user.php</user>
    <auto>https-post://cpee.org/services/timeout-auto.php</auto>
    <subprocess>https-post://cpee.org/flow/start/url/</subprocess>
    <timeout>https-post://cpee.org/services/timeout.php</timeout>
    <send>https-post://cpee.org/ing/correlators/message/send/</send>
    <receive>https-get://cpee.org/ing/correlators/message/receive/</receive>
  </endpoints>
  <attributes>
    <info>Enter info here</info>
    <modeltype>CPEE</modeltype>
    <theme>preset</theme>
  </attributes>
  <description>
    <description xmlns="http://cpee.org/ns/description/1.0">
      <call id="a2" endpoint="">
        <parameters>
          <label>Client Initiates Service</label>
          <method/>
          <type>:task</type>
          <mid>'1'</mid>
          <arguments/>
        </parameters>
      </call>
      <call id="a3" endpoint="">
        <parameters>
          <label>Enter Store and Look for Service</label>
          <method/>
          <type>:task</type>
          <mid>'2'</mid>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive">
        <alternative condition="Service Not Found" language="text/javascript"/>
        <alternative condition="Service Found" language="text/javascript">
          <call id="a6" endpoint="">
            <parameters>
              <label>Take Ticket</label>
              <method/>
              <type>:task</type>
              <mid>'5'</mid>
              <arguments/>
            </parameters>
          </call>
          <choose mode="exclusive">
            <alternative condition="Ticket in App" language="text/javascript">
              <call id="a8" endpoint="">
                <parameters>
                  <label>Wait and Check Criteria</label>
                  <method/>
                  <type>:task</type>
                  <mid>'7'</mid>
                  <arguments/>
                </parameters>
              </call>
            </alternative>
            <alternative condition="Physical Ticket" language="text/javascript">
              <call id="a9" endpoint="">
                <parameters>
                  <label>Wait for Turn</label>
                  <method/>
                  <type>:task</type>
                  <mid>'8'</mid>
                  <arguments/>
                </parameters>
              </call>
            </alternative>
          </choose>
          <call id="a10" endpoint="">
            <parameters>
              <label>Ask for Request</label>
              <method/>
              <type>:task</type>
              <mid>'9'</mid>
              <arguments/>
            </parameters>
          </call>
          <call id="a11" endpoint="">
            <parameters>
              <label>Communicate Request to Assistant</label>
              <method/>
              <type>:task</type>
              <mid>'10'</mid>
              <arguments/>
            </parameters>
          </call>
          <call id="a1" endpoint="">
            <parameters>
              <label>Register Request</label>
              <color/>
              <method>:post</method>
              <arguments/>
            </parameters>
            <annotations>
              <_generic/>
              <_logging_behavior>
                <_exclude>false</_exclude>
                <_include>false</_include>
              </_logging_behavior>
              <_timing>
                <_timing_weight/>
                <_timing_avg/>
                <explanations/>
              </_timing>
              <_shifting>
                <_shifting_type>Duration</_shifting_type>
              </_shifting>
              <_context_data_analysis>
                <probes/>
                <ips/>
              </_context_data_analysis>
              <report>
                <url/>
              </report>
              <_notes>
                <_notes_general/>
              </_notes>
            </annotations>
            <documentation>
              <input/>
              <output/>
              <implementation>
                <description/>
              </implementation>
            </documentation>
          </call>
          <loop mode="pre_test" condition="true">
            <call id="a13" endpoint="">
              <parameters>
                <label>Register Request</label>
                <method/>
                <type>:task</type>
                <mid>'12'</mid>
                <arguments/>
              </parameters>
            </call>
            <choose mode="exclusive">
              <alternative condition=""/>
              <alternative condition="">
                <escape/>
              </alternative>
            </choose>
          </loop>
          <call id="a15" endpoint="">
            <parameters>
              <label>Send Order Request</label>
              <method/>
              <type>:task</type>
              <mid>'14'</mid>
              <arguments/>
            </parameters>
          </call>
          <call id="a16" endpoint="">
            <parameters>
              <label>Prepare Order</label>
              <method/>
              <type>:task</type>
              <mid>'15'</mid>
              <arguments/>
            </parameters>
          </call>
          <call id="a17" endpoint="">
            <parameters>
              <label>Deliver Order</label>
              <method/>
              <type>:task</type>
              <mid>'16'</mid>
              <arguments/>
            </parameters>
          </call>
        </alternative>
      </choose>
    </description>
  </description>
  <transformation>
    <description type="copy"/>
    <dataelements type="none"/>
    <endpoints type="none"/>
  </transformation>
</testset>